# Copy to config.local.env (gitignored) and fill after tenant provisioning. NO SECRETS IN GIT.
TENANT_ID=""                 # Entra tenant GUID
GRAPH_TOKEN=""               # bearer token for Microsoft Graph (obtained interactively by the human)
PPAC_TOKEN=""                # bearer token for Power Platform admin API
ARM_TOKEN=""                 # bearer token for Azure Resource Manager
DATAVERSE_ENV_URL=""         # e.g. https://org.crm.dynamics.com
TEST_BOT_ID=""               # published Copilot Studio agent bot GUID
